{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/secrets/**)",
      "Read(./**/credentials*)",
      "Bash(cat .env*)",
      "Bash(cat *.env)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(rm -rf*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)"
    ],
    "ask": [
      "Bash(./gradlew bootRun*)",
      "Bash(npm install*)",
      "Bash(npm i *)",
      "Bash(docker compose down*)"
    ],
    "allow": [
      "Read(./**)",
      "Grep",
      "Glob",
      "Skill",
      "Bash(./gradlew test*)",
      "Bash(./gradlew build*)",
      "Bash(./gradlew spotlessApply*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(docker compose up*)",
      "Bash(openspec status:*)",
      "Bash(openspec instructions:*)",
      "Bash(openspec validate:*)",
      "Bash(openspec list:*)",
      "Bash(openspec show:*)",
      "Bash(npx openspec:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pii-secret-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format.sh"
          }
        ]
      }
    ]
  }
}
